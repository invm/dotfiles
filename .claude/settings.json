{
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(tail *)",
      "Bash(for *)",
      "Bash(sed *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(head *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(sqlite3 *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(test *)",
      "Bash(xargs *)",
      "Bash(date *)",
      "Bash(which *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(chmod *)",
      "Bash(./scripts/ci-status.sh *)",
      "Bash(scripts/ci-status.sh *)"
    ],
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "SendMessage",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "disableClaudeAiConnectors": true,
  "disableBundledSkills": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && [ \"$(tmux display -p -t \"$TMUX_PANE\" '#{window_active}')\" != \"1\" ] && tmux set-window-option -t \"$TMUX_PANE\" @status done_err 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && [ \"$(tmux display -p -t \"$TMUX_PANE\" '#{window_active}')\" != \"1\" ] && tmux set-window-option -t \"$TMUX_PANE\" @status done_ok 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "caveman@caveman": true,
    "notion@claude-plugins-official": false,
    "ponytail@ponytail": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
