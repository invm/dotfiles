{
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(tail *)",
      "Bash(for *)",
      "Bash(sed *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(head *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(sqlite3 *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(test *)",
      "Bash(xargs *)",
      "Bash(date *)",
      "Bash(which *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(chmod *)",
      "Bash(./scripts/ci-status.sh *)",
      "Bash(scripts/ci-status.sh *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && [ \"$(tmux display -p -t \"$TMUX_PANE\" '#{window_active}')\" != \"1\" ] && tmux set-window-option -t \"$TMUX_PANE\" @status done_err 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX_PANE\" ] && [ \"$(tmux display -p -t \"$TMUX_PANE\" '#{window_active}')\" != \"1\" ] && tmux set-window-option -t \"$TMUX_PANE\" @status done_ok 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "if": "Bash(git commit*)",
            "prompt": "This command is about to run a git commit. If it creates a commit message (-m or -F or heredoc), verify the message subject follows Conventional Commits: <type>(<optional scope>): <subject>, where type is one of feat, fix, chore, refactor, test, docs, style, perf, build, ci, revert. Fail with a reason naming the correct format if it does not. Pass if the command does not set a message (e.g. --amend --no-edit, merge continuation). $ARGUMENTS",
            "statusMessage": "Checking commit message convention"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "caveman@caveman": true,
    "notion@claude-plugins-official": false,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
